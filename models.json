{
  "providers": {
    "openrouter": {
      "modelOverrides": {
        "z-ai/glm-5.2": {
          "compat": {
            "openRouterRouting": {
              "only": ["streamlake"],
              "allow_fallbacks": false
            }
          }
        }
      }
    },
    "minimax": {
      "modelOverrides": {
        "MiniMax-M3": {
          "thinkingLevelMap": {
            "off": "low",
            "minimal": "high",
            "low": "high",
            "medium": "high",
            "high": "high",
            "xhigh": "high"
          },
          "compat": {
            "forceAdaptiveThinking": true
          }
        }
      }
    }
  }
}